    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "@types/yup": "^0.29.14",
    "axios": "^1.13.2",
    "cookie-parser": "^1.4.7",
