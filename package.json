{
  "name": "modular_factory",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "clean": "rimraf dist",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:dev:start": "node -e \"console.log('Using local Postgres; ensure it is running.')\"",
    "db:dev:stop": "node -e \"console.log('Local Postgres stop is manual.')\"",
    "db:dev:docker:start": "docker compose -f docker-compose.dev.yml up -d",
    "db:dev:docker:stop": "docker compose -f docker-compose.dev.yml down",
    "db:dev:push": "npx dotenv-cli -e .env.local -- prisma db push --accept-data-loss",
    "db:dev:seed": "npx ts-node scripts/seed-dev-plan.ts",
    "db:dev:reset": "npm run db:dev:push && npm run db:dev:seed",
    "db:studio": "prisma studio",
    "migrate:setup": "node scripts/migrate-to-prisma.js",
    "build:client": "npm install --prefix client && npm run build --prefix client",
    "gcp-build": "npm run db:generate && npm run build && npm run build:client"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
