PORT=
CORS_ORIGIN=

DATABASE_URL=


FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=
FIREBASE_TOKEN_URI=
FIREBASE_AUTH_PROVIDER_CERT_URL=
FIREBASE_CLIENT_CERT_URL=

# LLM Configuration
LLM_PROVIDER=openai                    # Options: openai | anthropic | gemini
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
LLM_MODEL=gpt-5-mini                       # Model name per provider
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1500

# Pinecone Configuration
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=hr-assistant
EMBEDDING_MODEL=text-embedding-3-large
CHUNK_SIZE=6000
CHUNK_OVERLAP=750

# LlamaParse Configuration (for PDF parsing with table preservation)
LLAMA_CLOUD_API_KEY=...                # Get from https://cloud.llamaindex.ai/

# Session Configuration
SESSION_TTL_HOURS=24                    # Session expiration time in hours
MAX_CONVERSATION_HISTORY=20             # Max number of messages to keep in session history
RETRIEVAL_TOP_K=10                       # Number of relevant chunks to retrieve from Pinecone

# Firebase Data Connect Configuration (for chat session persistence)
DATA_CONNECT_SERVICE_ID=vederra-dev-d4327-service
DATA_CONNECT_LOCATION=us-central1
FIREBASE_WEB_API_KEY=                   # Firebase Web API Key (for Data Connect client SDK)
USE_DATACONNECT_EMULATOR=false          # Set to true for local development with emulator

# Node Environment
NODE_ENV=development
