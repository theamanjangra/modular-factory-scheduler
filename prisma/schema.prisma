generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Existing Models ====================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  firstname String
  lastname  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Employee {
  id        Int       @id @default(autoincrement())
  name      String
  email     String?   @unique
  crews     String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  timelogs  Timelog[]

  @@map("employees")
}

model Timelog {
  id          Int      @id @default(autoincrement())
  employeeId  Int
  startTime   DateTime
  endTime     DateTime
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("timelogs")
}

model Plan {
  id            String                 @id @default(uuid())
  name          String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  inputSnapshot Json?
  assignments   WorkerTaskAssignment[]

  @@map("plans")
}

model WorkerTaskAssignment {
  id        String    @id @default(uuid())
  planId    String
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  workerId  String
  taskId    String
  shiftId   String?
  startTime DateTime
  endTime   DateTime
  status    String?   @default("WORKING")
  heldAt    DateTime?

  @@index([planId])
  @@index([workerId])
  @@index([taskId])
  @@index([status])
  @@map("worker_task_assignments")
}

// ==================== KAN-493: New Models ====================

model Shift {
  id          String    @id @default(uuid())
  name        String
  startTime   String    // e.g., "06:00"
  endTime     String    // e.g., "14:30"
  workers     Worker[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("shifts")
}

model Department {
  id            String          @id @default(uuid())
  name          String          @unique
  description   String?
  workers       Worker[]
  taskTemplates TaskTemplate[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@map("departments")
}

model ModuleProfile {
  id               String            @id @default(uuid())
  name             String
  description      String?
  moduleAttributes ModuleAttribute[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("module_profiles")
}

model ModuleAttribute {
  id              String        @id @default(uuid())
  moduleProfileId String
  moduleProfile   ModuleProfile @relation(fields: [moduleProfileId], references: [id], onDelete: Cascade)
  attributeName   String
  attributeValue  String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([moduleProfileId])
  @@map("module_attributes")
}

model TravelerTemplate {
  id            String         @id @default(uuid())
  name          String
  description   String?
  taskTemplates TaskTemplate[]
  timeStudies   TimeStudy[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("traveler_templates")
}

model TaskTemplate {
  id                  String           @id @default(uuid())
  travelerTemplateId  String
  travelerTemplate    TravelerTemplate @relation(fields: [travelerTemplateId], references: [id], onDelete: Cascade)
  taskName            String
  departmentId        String?
  department          Department?      @relation(fields: [departmentId], references: [id])
  minCrew             Int              @default(1)
  optimalCrew         Int              @default(1)
  maxCrew             Int              @default(4)
  laborHours          Float
  prerequisiteTaskIds String[]         @default([])
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([travelerTemplateId])
  @@index([departmentId])
  @@map("task_templates")
}

model TimeStudy {
  id                 String           @id @default(uuid())
  travelerTemplateId String
  travelerTemplate   TravelerTemplate @relation(fields: [travelerTemplateId], references: [id], onDelete: Cascade)
  taskName           String
  averageTime        Float            // in hours
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([travelerTemplateId])
  @@map("time_studies")
}

model Worker {
  id           String      @id @default(uuid())
  name         String
  crews        String[]
  shiftId      String?
  shift        Shift?      @relation(fields: [shiftId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([shiftId])
  @@index([departmentId])
  @@map("workers")
}