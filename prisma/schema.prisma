generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt       DateTime          @map("created_at") @db.Timestamptz(6)
  email           String?           @unique(map: "user_email_uidx")
  firebaseUserId  String?           @map("firebase_user_id")
  firstname       String
  lastActivity    DateTime?         @map("last_activity") @db.Timestamptz(6)
  lastname        String
  phone           String            @unique(map: "user_phone_uidx")
  type            UserType
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  notes           Note[]
  projectContacts ProjectContact[]
  warranty_claims warranty_claims[]

  @@map("user")
}

model Project {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String?
  moduleProfiles  ModuleProfile[]
  projectContacts ProjectContact[]
  warranty_claims warranty_claims[]

  @@map("project")
}

model ModuleProfile {
  id                            String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  projectId                     String?                        @map("project_id") @db.Uuid
  name                          String?
  modules                       Module[]
  moduleCharacteristics         ModuleCharacteristic[]
  project                       Project?                       @relation(fields: [projectId], references: [id], onUpdate: NoAction)
  moduleProfileModuleAttributes ModuleProfileModuleAttribute[]
  travelers                     Traveler[]

  @@index([projectId], map: "module_profile_projectId_idx")
  @@map("module_profile")
}

model ModuleCharacteristic {
  id                 String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  moduleProfileId    String                    @map("module_profile_id") @db.Uuid
  characteristicType ModuleCharacteristicType? @map("characteristic_type")
  value              Float?
  moduleProfile      ModuleProfile             @relation(fields: [moduleProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([moduleProfileId], map: "module_characteristic_moduleProfileId_idx")
  @@map("module_characteristic")
}

model Module {
  id                                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  moduleProfileId                     String           @map("module_profile_id") @db.Uuid
  travelerId                          String?          @map("traveler_id") @db.Uuid
  travelerTemplateId                  String           @map("traveler_template_id") @db.Uuid
  order                               Int?
  serialNumber                        String?          @map("serial_number")
  moduleProfile                       ModuleProfile    @relation(fields: [moduleProfileId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  traveler                            Traveler?        @relation("ModuleTraveler", fields: [travelerId], references: [id], onUpdate: NoAction)
  travelerTemplate                    TravelerTemplate @relation(fields: [travelerTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  timeStudies                         TimeStudy[]
  traveler_traveler_module_idTomodule Traveler[]       @relation("traveler_module_idTomodule")

  @@index([moduleProfileId], map: "module_moduleProfileId_idx")
  @@index([travelerId], map: "module_travelerId_idx")
  @@index([travelerTemplateId], map: "module_travelerTemplateId_idx")
  @@map("module")
}

model TravelerTemplate {
  id                                      String                                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt                               DateTime?                                @map("created_at") @db.Timestamptz(6)
  name                                    String?
  updatedAt                               DateTime?                                @updatedAt @map("updated_at") @db.Timestamptz(6)
  modules                                 Module[]
  travelers                               Traveler[]
  travelerTemplateInspectionItemTemplates TravelerTemplateInspectionItemTemplate[]
  travelerTemplateTaskTemplates           TravelerTemplateTaskTemplate[]

  @@map("traveler_template")
}

model Traveler {
  id                                String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  moduleId                          String                   @map("module_id") @db.Uuid
  moduleProfileId                   String?                  @map("module_profile_id") @db.Uuid
  siblingId                         String?                  @map("sibling_id") @db.Uuid
  travelerTemplateId                String                   @map("traveler_template_id") @db.Uuid
  createdAt                         DateTime?                @map("created_at") @db.Timestamptz(6)
  isShipped                         Boolean?                 @map("is_shipped")
  notesRequiredUpload               Boolean?                 @map("notes_required_upload")
  serialNumber                      String?                  @map("serial_number")
  updatedAt                         DateTime?                @updatedAt @map("updated_at") @db.Timestamptz(6)
  adhocInspectionItems              AdhocInspectionItem[]
  adhocTasks                        AdhocTask[]
  inspectionItems                   InspectionItem[]
  modules                           Module[]                 @relation("ModuleTraveler")
  notes                             Note[]
  tasks                             Task[]
  module_traveler_module_idTomodule Module                   @relation("traveler_module_idTomodule", fields: [moduleId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  moduleProfile                     ModuleProfile?           @relation(fields: [moduleProfileId], references: [id], onUpdate: NoAction)
  sibling                           Traveler?                @relation("TravelerSibling", fields: [siblingId], references: [id], onUpdate: NoAction)
  siblingOf                         Traveler[]               @relation("TravelerSibling")
  travelerTemplate                  TravelerTemplate         @relation(fields: [travelerTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  travelerInspectionAreas           TravelerInspectionArea[]
  travelerStations                  TravelerStation[]

  @@index([moduleId], map: "traveler_moduleId_idx")
  @@index([moduleProfileId], map: "traveler_moduleProfileId_idx")
  @@index([siblingId], map: "traveler_siblingId_idx")
  @@index([travelerTemplateId], map: "traveler_travelerTemplateId_idx")
  @@map("traveler")
}

model InspectionArea {
  id                          String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  createdAt                   DateTime?                @map("created_at") @db.Timestamptz(6)
  name                        String?
  order                       Int?
  updatedAt                   DateTime?                @updatedAt @map("updated_at") @db.Timestamptz(6)
  adhocInspectionItems        AdhocInspectionItem[]    @relation("AdhocInspectionArea")
  adhocInspectionItemsNewArea AdhocInspectionItem[]    @relation("NewAdhocInspectionArea")
  inspectionItemsNewArea      InspectionItem[]         @relation("NewInspectionArea")
  inspectionItemTemplates     InspectionItemTemplate[]
  stations                    Station[]
  travelerInspectionAreas     TravelerInspectionArea[]

  @@map("inspection_area")
}

model Station {
  id                              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  inspectionAreaId                String?           @map("inspection_area_id") @db.Uuid
  canReceiveMultipleTravelers     Boolean?          @map("can_receive_multiple_travelers")
  doesReceiveTravelers            Boolean?          @map("does_receive_travelers")
  name                            String?
  order                           Int?
  adhocTasksNewStation            AdhocTask[]       @relation("AdhocTaskNewStation")
  adhocTasks                      AdhocTask[]
  inspectionArea                  InspectionArea?   @relation(fields: [inspectionAreaId], references: [id], onUpdate: NoAction)
  tasksNewStation                 Task[]            @relation("TaskNewStation")
  taskTemplates                   TaskTemplate[]
  taskTemplatesSubassemblyRelease TaskTemplate[]    @relation("SubassemblyReleaseStation")
  travelerStations                TravelerStation[]
  workersNewStation               Worker[]          @relation("WorkerNewStation")
  workers                         Worker[]

  @@index([inspectionAreaId], map: "station_inspectionAreaId_idx")
  @@map("station")
}

model TravelerStation {
  id                     String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  stationId              String   @map("station_id") @db.Uuid
  travelerId             String   @map("traveler_id") @db.Uuid
  isCurrent              Boolean? @map("is_current")
  leadInspectionProgress Float?   @map("lead_inspection_progress")
  qamInspectionProgress  Float?   @map("qam_inspection_progress")
  taskProgress           Float?   @map("task_progress")
  station                Station  @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  traveler               Traveler @relation(fields: [travelerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([stationId], map: "traveler_station_stationId_idx")
  @@index([travelerId], map: "traveler_station_travelerId_idx")
  @@map("traveler_station")
}

model InspectionItemTemplate {
  id                                      String                                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  departmentId                            String?                                  @map("department_id") @db.Uuid
  inspectionAreaId                        String                                   @map("inspection_area_id") @db.Uuid
  description                             String?
  isPhotoRequired                         Boolean?                                 @map("is_photo_required")
  isVideoRequired                         Boolean?                                 @map("is_video_required")
  name                                    String?
  order                                   Int?
  inspectionItems                         InspectionItem[]
  department                              Department?                              @relation(fields: [departmentId], references: [id], onUpdate: NoAction)
  inspectionArea                          InspectionArea                           @relation(fields: [inspectionAreaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  travelerTemplateInspectionItemTemplates TravelerTemplateInspectionItemTemplate[]

  @@index([departmentId], map: "inspection_item_template_departmentId_idx")
  @@index([inspectionAreaId], map: "inspection_item_template_inspectionAreaId_idx")
  @@map("inspection_item_template")
}

model InspectionItem {
  id                       String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  inspectionItemTemplateId String                 @map("inspection_item_template_id") @db.Uuid
  newInspectionAreaId      String?                @map("new_inspection_area_id") @db.Uuid
  travelerId               String                 @map("traveler_id") @db.Uuid
  isMoveRequested          Boolean?               @map("is_move_requested")
  isMoved                  Boolean?               @map("is_moved")
  leadStatus               TaskStatus?            @map("lead_status")
  qamStatus                TaskStatus?            @map("qam_status")
  inspectionItemTemplate   InspectionItemTemplate @relation(fields: [inspectionItemTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  newInspectionArea        InspectionArea?        @relation("NewInspectionArea", fields: [newInspectionAreaId], references: [id], onUpdate: NoAction)
  traveler                 Traveler               @relation(fields: [travelerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  issues                   Issue[]
  notes                    Note[]

  @@index([inspectionItemTemplateId], map: "inspection_item_inspectionItemTemplateId_idx")
  @@index([newInspectionAreaId], map: "inspection_item_newInspectionAreaId_idx")
  @@index([travelerId], map: "inspection_item_travelerId_idx")
  @@map("inspection_item")
}

model TaskTemplate {
  id                              String                         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  departmentId                    String                         @map("department_id") @db.Uuid
  prerequisiteTaskTemplateId      String?                        @map("prerequisite_task_template_id") @db.Uuid
  stationId                       String                         @map("station_id") @db.Uuid
  subassemblyTaskReleaseStationId String?                        @map("subassembly_task_release_station_id") @db.Uuid
  description                     String?
  isPhotoRequired                 Boolean                        @default(false) @map("is_photo_required")
  isVideoRequired                 Boolean                        @default(false) @map("is_video_required")
  maxWorkers                      Int                            @map("max_workers")
  minWorkers                      Int                            @map("min_workers")
  name                            String
  nonWorkerTaskDuration           Float?                         @map("non_worker_task_duration")
  order                           Int
  rankedSkills                    Skill[]                        @map("ranked_skills")
  taskType                        TaskType                       @map("task_type")
  tasks                           Task[]
  department                      Department                     @relation(fields: [departmentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  prerequisiteTaskTemplate        TaskTemplate?                  @relation("TaskPrerequisite", fields: [prerequisiteTaskTemplateId], references: [id], onUpdate: NoAction)
  dependentTaskTemplates          TaskTemplate[]                 @relation("TaskPrerequisite")
  station                         Station                        @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subassemblyTaskReleaseStation   Station?                       @relation("SubassemblyReleaseStation", fields: [subassemblyTaskReleaseStationId], references: [id], onUpdate: NoAction)
  taskTemplateModuleAttributes    TaskTemplateModuleAttribute[]
  timeStudies                     TimeStudy[]
  travelerTemplateTaskTemplates   TravelerTemplateTaskTemplate[]
  workerTaskTemplates             WorkerTaskTemplate[]

  @@index([departmentId], map: "task_template_departmentId_idx")
  @@index([prerequisiteTaskTemplateId], map: "task_template_prerequisiteTaskTemplateId_idx")
  @@index([stationId], map: "task_template_stationId_idx")
  @@index([subassemblyTaskReleaseStationId], map: "task_template_subassemblyTaskReleaseStationId_idx")
  @@map("task_template")
}

model Task {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  newStationId      String?            @map("new_station_id") @db.Uuid
  taskTemplateId    String             @map("task_template_id") @db.Uuid
  travelerId        String             @map("traveler_id") @db.Uuid
  createdAt         DateTime           @map("created_at") @db.Timestamptz(6)
  isMoveRequested   Boolean?           @map("is_move_requested")
  isMoved           Boolean?           @map("is_moved")
  leadStatus        TaskStatus?        @map("lead_status")
  qamStatus         TaskStatus?        @map("qam_status")
  issues            Issue[]
  notes             Note[]
  newStation        Station?           @relation("TaskNewStation", fields: [newStationId], references: [id], onUpdate: NoAction)
  taskTemplate      TaskTemplate       @relation(fields: [taskTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  traveler          Traveler           @relation(fields: [travelerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  taskInterruptions TaskInterruption[]
  workerTasks       WorkerTask[]

  @@index([newStationId], map: "task_newStationId_idx")
  @@index([taskTemplateId], map: "task_taskTemplateId_idx")
  @@index([travelerId], map: "task_travelerId_idx")
  @@map("task")
}

model AdhocTask {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  departmentId    String?     @map("department_id") @db.Uuid
  newStationId    String?     @map("new_station_id") @db.Uuid
  stationId       String      @map("station_id") @db.Uuid
  travelerId      String      @map("traveler_id") @db.Uuid
  isMoveRequested Boolean?    @map("is_move_requested")
  isMoved         Boolean?    @map("is_moved")
  isPhotoRequired Boolean?    @map("is_photo_required")
  isVideoRequired Boolean?    @map("is_video_required")
  leadStatus      TaskStatus? @map("lead_status")
  order           Int?
  qamStatus       TaskStatus? @map("qam_status")
  department      Department? @relation(fields: [departmentId], references: [id], onUpdate: NoAction)
  newStation      Station?    @relation("AdhocTaskNewStation", fields: [newStationId], references: [id], onUpdate: NoAction)
  station         Station     @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  traveler        Traveler    @relation(fields: [travelerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notes           Note[]

  @@index([departmentId], map: "adhoc_task_departmentId_idx")
  @@index([newStationId], map: "adhoc_task_newStationId_idx")
  @@index([stationId], map: "adhoc_task_stationId_idx")
  @@index([travelerId], map: "adhoc_task_travelerId_idx")
  @@map("adhoc_task")
}

model AdhocInspectionItem {
  id                  String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  departmentId        String?         @map("department_id") @db.Uuid
  inspectionAreaId    String          @map("inspection_area_id") @db.Uuid
  newInspectionAreaId String?         @map("new_inspection_area_id") @db.Uuid
  travelerId          String          @map("traveler_id") @db.Uuid
  isMoveRequested     Boolean?        @map("is_move_requested")
  isMoved             Boolean?        @map("is_moved")
  isPhotoRequired     Boolean?        @map("is_photo_required")
  isVideoRequired     Boolean?        @map("is_video_required")
  leadStatus          TaskStatus?     @map("lead_status")
  order               Int?
  qamStatus           TaskStatus?     @map("qam_status")
  department          Department?     @relation(fields: [departmentId], references: [id], onUpdate: NoAction)
  inspectionArea      InspectionArea  @relation("AdhocInspectionArea", fields: [inspectionAreaId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  newInspectionArea   InspectionArea? @relation("NewAdhocInspectionArea", fields: [newInspectionAreaId], references: [id], onUpdate: NoAction)
  traveler            Traveler        @relation(fields: [travelerId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  notes               Note[]

  @@index([departmentId], map: "adhoc_inspection_item_departmentId_idx")
  @@index([inspectionAreaId], map: "adhoc_inspection_item_inspectionAreaId_idx")
  @@index([newInspectionAreaId], map: "adhoc_inspection_item_newInspectionAreaId_idx")
  @@index([travelerId], map: "adhoc_inspection_item_travelerId_idx")
  @@map("adhoc_inspection_item")
}

model Issue {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  inspectionItemId String?         @map("inspection_item_id") @db.Uuid
  taskId           String?         @map("task_id") @db.Uuid
  description      String?
  isResolved       Boolean?        @map("is_resolved")
  name             String?
  type             IssueType?
  inspectionItem   InspectionItem? @relation(fields: [inspectionItemId], references: [id], onUpdate: NoAction)
  task             Task?           @relation(fields: [taskId], references: [id], onUpdate: NoAction)

  @@index([inspectionItemId], map: "issue_inspectionItemId_idx")
  @@index([taskId], map: "issue_taskId_idx")
  @@map("issue")
}

model Worker {
  id                  String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  newStationId        String?              @map("new_station_id") @db.Uuid
  shiftId             String?              @map("shift_id") @db.Uuid
  stationId           String               @map("station_id") @db.Uuid
  canClockExtraTime   Boolean?             @map("can_clock_extra_time")
  customClockInDate   DateTime?            @map("custom_clock_in_date") @db.Timestamptz(6)
  customClockOutDate  DateTime?            @map("custom_clock_out_date") @db.Timestamptz(6)
  employeeId          String?              @map("employee_id")
  firstName           String?              @map("first_name")
  lastName            String?              @map("last_name")
  passcode            String?
  phone               String?
  rankedSkills        Skill[]              @map("ranked_skills")
  role                WorkerRole?
  devices             Device[]
  extraClockTimes     ExtraClockTime[]
  notifications       Notification[]
  ptoRequests         PtoRequest[]
  timeLogs            TimeLog[]
  newStation          Station?             @relation("WorkerNewStation", fields: [newStationId], references: [id], onUpdate: NoAction)
  shift               Shift?               @relation(fields: [shiftId], references: [id], onUpdate: NoAction)
  station             Station              @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workerDepartments   WorkerDepartment[]
  workerTasks         WorkerTask[]
  workerTaskTemplates WorkerTaskTemplate[]

  @@index([newStationId], map: "worker_newStationId_idx")
  @@index([shiftId], map: "worker_shiftId_idx")
  @@index([stationId], map: "worker_stationId_idx")
  @@map("worker")
}

model WorkerTask {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  taskId             String    @map("task_id") @db.Uuid
  workerId           String    @map("worker_id") @db.Uuid
  endDate            DateTime? @map("end_date") @db.Timestamptz(6)
  scheduledEndDate   DateTime? @map("scheduled_end_date") @db.Timestamptz(6)
  scheduledStartDate DateTime? @map("scheduled_start_date") @db.Timestamptz(6)
  startDate          DateTime? @map("start_date") @db.Timestamptz(6)
  task               Task      @relation(fields: [taskId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  worker             Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([taskId], map: "worker_task_taskId_idx")
  @@index([workerId], map: "worker_task_workerId_idx")
  @@map("worker_task")
}

model TimeLog {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workerId             String    @map("worker_id") @db.Uuid
  actualClockInDate    DateTime? @map("actual_clock_in_date") @db.Timestamptz(6)
  actualClockOutDate   DateTime? @map("actual_clock_out_date") @db.Timestamptz(6)
  officialClockInDate  DateTime? @map("official_clock_in_date") @db.Timestamptz(6)
  officialClockOutDate DateTime? @map("official_clock_out_date") @db.Timestamptz(6)
  worker               Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([workerId], map: "time_log_workerId_idx")
  @@map("time_log")
}

model Note {
  id                    String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  adhocInspectionItemId String?              @map("adhoc_inspection_item_id") @db.Uuid
  adhocTaskId           String?              @map("adhoc_task_id") @db.Uuid
  inspectionItemId      String?              @map("inspection_item_id") @db.Uuid
  taskId                String?              @map("task_id") @db.Uuid
  travelerId            String?              @map("traveler_id") @db.Uuid
  userId                String?              @map("user_id") @db.Uuid
  warrantyClaimId       String?              @map("warranty_claim_id") @db.Uuid
  createdAt             DateTime             @map("created_at") @db.Timestamptz(6)
  text                  String?
  type                  NoteType?
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  managedFiles          ManagedFile[]
  adhocInspectionItem   AdhocInspectionItem? @relation(fields: [adhocInspectionItemId], references: [id], onUpdate: NoAction)
  adhocTask             AdhocTask?           @relation(fields: [adhocTaskId], references: [id], onUpdate: NoAction)
  inspectionItem        InspectionItem?      @relation(fields: [inspectionItemId], references: [id], onUpdate: NoAction)
  task                  Task?                @relation(fields: [taskId], references: [id], onUpdate: NoAction)
  traveler              Traveler?            @relation(fields: [travelerId], references: [id], onUpdate: NoAction)
  user                  User?                @relation(fields: [userId], references: [id], onUpdate: NoAction)
  warrantyClaim         warranty_claims?     @relation(fields: [warrantyClaimId], references: [id], onUpdate: NoAction)

  @@index([adhocInspectionItemId], map: "note_adhocInspectionItemId_idx")
  @@index([adhocTaskId], map: "note_adhocTaskId_idx")
  @@index([inspectionItemId], map: "note_inspectionItemId_idx")
  @@index([taskId], map: "note_taskId_idx")
  @@index([travelerId], map: "note_travelerId_idx")
  @@index([userId], map: "note_userId_idx")
  @@index([warrantyClaimId], map: "note_warrantyClaimId_idx")
  @@map("note")
}

model ManagedFile {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  noteId            String?           @map("note_id") @db.Uuid
  contentType       String?           @map("content_type")
  createdAt         DateTime          @map("created_at") @db.Timestamptz(6)
  filename          String?
  isAuthRequired    Boolean?          @map("is_auth_required")
  isUploaded        Boolean?          @map("is_uploaded")
  shouldBePublic    Boolean?          @map("should_be_public")
  shouldCache       Boolean?          @map("should_cache")
  shouldDeferUpload Boolean?          @map("should_defer_upload")
  storageDir        StorageDirectory? @map("storage_dir")
  uploadAttempts    Int?              @map("upload_attempts")
  note              Note?             @relation(fields: [noteId], references: [id], onUpdate: NoAction)

  @@index([noteId], map: "managed_file_noteId_idx")
  @@map("managed_file")
}

model TravelerTemplateInspectionItemTemplate {
  id                       String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  inspectionItemTemplateId String                 @map("inspection_item_template_id") @db.Uuid
  travelerTemplateId       String                 @map("traveler_template_id") @db.Uuid
  inspectionItemTemplate   InspectionItemTemplate @relation(fields: [inspectionItemTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ttiit_tmp")
  travelerTemplate         TravelerTemplate       @relation(fields: [travelerTemplateId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_ttiit_trv")

  @@index([travelerTemplateId], map: "traveler_template_inspection_item_templa_travelerTemplateId_idx")
  @@index([inspectionItemTemplateId], map: "traveler_template_inspection_item_templactionItemTemplateId_idx")
  @@map("traveler_template_inspection_item_template")
}

model TravelerTemplateTaskTemplate {
  id                 String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  taskTemplateId     String           @map("task_template_id") @db.Uuid
